{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_*",
        "SUPABASE_PROJECT_REF",
        "SUPABASE_SERVICE_ROLE_KEY",
        "DATABASE_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "lint:fix": {
      "dependsOn": ["transit"],
      "cache": false
    },
    "//#format:root": {
      "inputs": [
        "*.{json,md,yaml,yml}",
        "!pnpm-lock.yaml",
        "!skills-lock.json",
        "docs/**/*.{json,md,yaml,yml}",
        ".prettierignore"
      ],
      "cache": false
    },
    "//#format:root:check": {
      "inputs": [
        "*.{json,md,yaml,yml}",
        "!pnpm-lock.yaml",
        "!skills-lock.json",
        "docs/**/*.{json,md,yaml,yml}",
        ".prettierignore"
      ]
    },
    "format": {
      "dependsOn": ["transit", "//#format:root"],
      "cache": false
    },
    "format:check": {
      "dependsOn": ["transit", "//#format:root:check"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "dev": {
      "cache": false,
      "env": [
        "NEXT_PUBLIC_SUPABASE_*",
        "SUPABASE_PROJECT_REF",
        "SUPABASE_SERVICE_ROLE_KEY",
        "DATABASE_URL"
      ],
      "persistent": true
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["transit"],
      "outputs": ["storybook-static/**"]
    }
  }
}
